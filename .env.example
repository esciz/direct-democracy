DATABASE_URL="postgresql://postgres:postgres@localhost:5432/direct_democracy?schema=public"
NEXT_PUBLIC_ENABLE_DEMO_MODE="true"
NEWS_API_KEY="replace-with-newsapi-key"
GOV_CRM_ENABLED="false"
ADMIN_PREVIEW_ENABLED="false"

# Dedicated operations-console authentication. Do not reuse demo credentials.
ADMIN_EMAIL="admin@example.org"
ADMIN_PASSWORD="replace-with-a-long-random-password"
ADMIN_SESSION_SECRET="replace-with-at-least-32-random-characters"

# Native background jobs are enabled automatically in development. Set this to
# true only on a persistent self-hosted application/worker. Vercel execution is
# intentionally disabled because its local filesystem and detached processes
# are not durable.
ADMIN_OPERATIONS_ENABLED="false"
