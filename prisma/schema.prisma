generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  citizen
  trustedCitizen
  candidate
  official
  media
  moderator
  admin
}

enum PublicProfileType {
  citizen
  trustedCitizen
  candidate
  official
  media
  incumbentCandidate
}

enum ElectionType {
  PRIMARY
  GENERAL
  SPECIAL
  RUNOFF
  LOCAL
}

enum ElectionStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum CampaignStatus {
  ANNOUNCED
  ACTIVE
  SUSPENDED
  WITHDRAWN
  WON
  LOST
}

enum PublicProfileSource {
  admin
  user
}

enum ClaimStatus {
  UNCLAIMED
  PENDING
  CLAIMED
}

enum JurisdictionType {
  COUNTRY
  STATE
  COUNTY
  CITY
  DISTRICT
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
}

enum PostContentType {
  statementClaim
  newsStory
  opinionPerspective
  announcementUpdate
  event
  questionPoll
}

enum MediaTier {
  trustedSource
  verifiedMedia
}

enum MediaBiasRatingValue {
  FarLeft
  Left
  Center
  Right
  FarRight
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PetitionStatus {
  DRAFT
  ACTIVE
  ELIGIBLE_FOR_COSPONSORSHIP
  CLOSED
}

enum SignatureStatus {
  PENDING
  VALID
  REJECTED
}

enum VoteQuestionCategory {
  civic
  lifestyle
  identity
}

enum VoteAnswer {
  yes
  no
  skip
}

enum TruthRatingValue {
  Accurate
  MostlyTrue
  MixedUnclear
  Misleading
  False
}

enum VoteQuestionScope {
  local
  state
  national
}

enum TopIssueSource {
  curated
  writeIn
}

enum FavoriteSpotType {
  restaurant
  bar
  coffeeShop
  park
  hikeOutdoor
  museumCulture
  activityEntertainment
}

enum ProfileTagCategory {
  religion
  sexualOrientation
  genderIdentity
  profession
  lifestyle
  interests
  community
}

enum ServiceCategory {
  Housing
  Education
  Transportation
  Permits
  Utilities
  PublicSafety
}

enum CommunityDataLevel {
  city
  county
  state
  federal
}

enum CreditBoostTarget {
  issue
  voice
}

enum CreditTransactionType {
  vote
  pollVote
  endorsement
  petition
}

enum NotificationType {
  petitionSeekingSponsor
  petitionSponsorFound
  petitionDrafting
  pollConvertedToPetition
  debateChallenge
  debateGroupJoin
  debateUpdate
  debateFollowedUserJoined
  debateCompleted
  debateResolved
  followeeTrustedCitizen
  followeeCandidate
  followeeOfficial
  messageRequest
  messageThreadUpdate
  messageReplyReceived
  organizationAnnouncement
  followeePost
  followeeMajorAction
}

enum OrganizationType {
  campus_org
  coalition
}

enum OrganizationMembershipRole {
  founder
  admin
  member
}

enum OrganizationMembershipState {
  pending
  approved
  declined
}

enum OrganizationPlatformItemStatus {
  draft
  active
  adopted
}

enum OrganizationVoteChoice {
  support
  oppose
}

enum MessageRequestState {
  pending
  accepted
  ignored
  blocked
  reported
}

enum MessageAudienceRule {
  everyone
  followersOnly
  jurisdictionOnly
}

enum LegislationChangeVote {
  adopt
  reject
}

enum CaseCourtLevel {
  local
  state
  federal
}

enum CaseStage {
  trial
  appeal
  cert
  merits
}

enum CaseStatus {
  active
  watching
  closed
}

enum ContactActionTargetType {
  issue
  petition
  legislation
}

enum ContactMethod {
  email
  phone
  form
}

enum OfficialActionType {
  voteCast
  billSponsored
  billCoSponsored
  executiveAction
  publicStatement
  meetingHeld
  budgetProposal
  policyAnnouncement
  committeeAction
}

enum OfficialActionSourceType {
  official
  media
  citizen
}

enum OfficialActionVerificationStatus {
  unverified
  sourced
  verified
}

enum OfficialActionReactionType {
  support
  oppose
}

enum DebateMode {
  individual
  group
}

enum DebateStatus {
  open
  completed
  withdrawn
  agreed
}

enum DebateOutcomeType {
  resolved_by_agreement
  withdrawn
  completed
}

enum DebateStartState {
  pendingChallenge
  seekingParticipants
  active
}

enum DebateSide {
  A
  B
}

enum DebateParticipantRole {
  lead
  member
}

enum DebateTurnType {
  opening
  response
  closing
}

enum DebateTurnReactionType {
  support
  oppose
}

enum DebateCommunityVoteOption {
  A
  B
  noClearWinner
}

enum DebateFallacyReviewPosition {
  agree
  disagree
}

enum DebateFallacyType {
  AdHominem
  StrawMan
  RedHerring
  FalseDichotomy
  SlipperySlope
  AppealToEmotion
  HastyGeneralization
  CircularReasoning
  Whataboutism
}

enum CitationSourceType {
  government
  academic
  news
  organization
}

enum CommunityGroupType {
  tradeUnion
  chamberOfCommerce
  neighborhoodAssociation
  advocacyOrganization
  parentTeacherGroup
  veteransGroup
  environmentalGroup
  smallBusinessGroup
  faithCommunityService
  professionalAssociation
}

enum PromiseStatus {
  Achieved
  InProgress
  Reversed
}

enum CommunityEventType {
  remoteMeeting
  inPersonMeeting
  demonstration
  rally
  civicForum
  communityDiscussion
}

enum CommunityEventFormat {
  virtual
  inPerson
}

enum EventRsvpStatus {
  attending
  maybe
  confirmed
}

enum EventStatementPosition {
  support
  dissent
  neutral
}

enum CommunitySponsorType {
  trustedCitizen
  official
  candidate
  community
}

model User {
  id                    String            @id @default(cuid())
  email                 String            @unique
  username              String            @unique
  name                  String
  bio                   String?
  avatarUrl             String?
  role                  UserRole          @default(citizen)
  mediaTier             MediaTier?
  isVerifiedVoter       Boolean           @default(false)
  isAnonymousPublic     Boolean           @default(true)
  followerCount         Int               @default(0)
  trustedCitizenAt      DateTime?
  jurisdictionId        String?
  jurisdiction          Jurisdiction?     @relation(fields: [jurisdictionId], references: [id])
  posts                 Post[]
  comments              Comment[]
  factualClaimFlags     PostFactualClaimFlag[]
  truthRatings          TruthRating[]
  mediaBiasRatings      MediaBiasRating[]
  petitionsCreated      Petition[]
  petitionSignatures    PetitionSignature[]
  voteResponses         VoteResponse[]
  candidateEndorsements CandidateEndorsement[]
  polls                 Poll[]
  pollVotes             PollVote[]
  topIssueSubmissions   TopIssueSubmission[]
  topIssueUpvotes       TopIssueUpvote[]
  topIssues             UserTopIssue[]
  userTags              UserTag[]
  favoriteSpots         FavoriteSpot[]
  creditTransactions    CreditTransaction[]
  creditBoosts          CreditBoost[]
  notifications         Notification[]
  contactActions        ContactAction[]
  caseFollows          CaseFollow[]
  caseSupportStatements SupportStatement[]
  communityBriefThemes  CommunityBriefTheme[]
  communityBriefThemeSupports CommunityBriefThemeSupport[]
  communityGroupAffiliations CommunityGroupAffiliation[]
  communityEvents      CommunityEvent[]
  following            Follow[]           @relation("FollowFollower")
  followers            Follow[]           @relation("FollowFollowing")
  publicProfile         PublicProfile?     @relation("ClaimedPublicProfile")
  officialProfile       OfficialProfile?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([jurisdictionId])
  @@index([role])
}

model UserProfileContent {
  userId             String   @id
  localIssues        String[]
  stateIssues        String[]
  nationalIssues     String[]
  groupTags          String[]
  profession         String?
  experience         String?
  professionPublic   Boolean  @default(false)
  experiencePublic   Boolean  @default(false)
  recentVotesPublic  Boolean  @default(false)
  bookmarkedScopes   VoteQuestionScope[]
  user               User     @relation(fields: [userId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserIdentityTag {
  id        String             @id @default(cuid())
  userId    String
  category  ProfileTagCategory
  value     String
  isCustom  Boolean            @default(false)
  isPublic  Boolean            @default(false)
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])

  @@index([userId, category])
}

model UserTopIssue {
  id        String            @id @default(cuid())
  userId    String
  scope     VoteQuestionScope
  value     String
  isCustom  Boolean           @default(false)
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id])

  @@index([userId, scope])
}

model UserTag {
  id        String   @id @default(cuid())
  userId    String
  value     String
  isCustom  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model IssueSnapshot {
  id          String            @id @default(cuid())
  communityId String
  scope       VoteQuestionScope
  issue       String
  percentage  Int
  date        DateTime

  @@index([communityId, scope, date])
}

model FavoriteSpot {
  id          String           @id @default(cuid())
  userId      String
  name        String
  type        FavoriteSpotType
  user        User             @relation(fields: [userId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

model Case {
  id                   String               @id @default(cuid())
  title                String
  summary              String
  courtLevel           CaseCourtLevel
  stage                CaseStage
  jurisdictionId       String?
  issueTags            String[]
  status               CaseStatus           @default(active)
  keyDatesJson         Json?
  createdAt            DateTime             @default(now())
  jurisdiction         Jurisdiction?        @relation(fields: [jurisdictionId], references: [id])
  follows              CaseFollow[]
  supportStatements    SupportStatement[]
  communityBriefThemes CommunityBriefTheme[]

  @@index([jurisdictionId])
  @@index([courtLevel, stage])
}

model CaseFollow {
  id        String   @id @default(cuid())
  caseId     String
  userId     String
  createdAt  DateTime @default(now())
  case       Case     @relation(fields: [caseId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([caseId, userId])
  @@index([userId])
}

model SupportStatement {
  id        String   @id @default(cuid())
  caseId     String
  userId     String
  statement  String
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  case       Case     @relation(fields: [caseId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([caseId, userId])
  @@index([caseId, createdAt])
}

model CommunityBriefTheme {
  id          String   @id @default(cuid())
  caseId       String
  creatorUserId String
  title        String
  description  String
  createdAt    DateTime @default(now())
  case         Case     @relation(fields: [caseId], references: [id])
  creator      User     @relation(fields: [creatorUserId], references: [id])
  supports     CommunityBriefThemeSupport[]

  @@index([caseId, createdAt])
}

model CommunityBriefThemeSupport {
  id        String   @id @default(cuid())
  themeId    String
  userId     String
  createdAt  DateTime @default(now())
  theme      CommunityBriefTheme @relation(fields: [themeId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([themeId, userId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  entityId  String
  contextEntityId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model MessageThread {
  id                 String              @id @default(cuid())
  citizenUserId      String
  publicFigureUserId String
  publicProfileId    String
  requestState       MessageRequestState @default(pending)
  initiatedByUserId  String
  createdAt          DateTime            @default(now())
}

model DirectMessage {
  id         String   @id @default(cuid())
  threadId    String
  senderUserId String
  body       String
  createdAt   DateTime @default(now())
}

model MessagePreference {
  id           String              @id @default(cuid())
  userId       String              @unique
  audienceRule MessageAudienceRule @default(everyone)
}

model MessageModerationAction {
  id         String              @id @default(cuid())
  threadId    String
  userId      String
  actionState MessageRequestState
  createdAt   DateTime            @default(now())
}

model ProposedChange {
  id               String   @id @default(cuid())
  legislationId    String
  userId           String
  changeText       String
  sectionReference String?
  createdAt        DateTime @default(now())
}

model ProposedChangeVote {
  id         String               @id @default(cuid())
  changeId    String
  userId      String
  vote       LegislationChangeVote
  createdAt   DateTime             @default(now())
}

model Follow {
  id              String   @id @default(cuid())
  followerUserId  String
  followingUserId String
  createdAt       DateTime @default(now())
  follower        User     @relation("FollowFollower", fields: [followerUserId], references: [id])
  following       User     @relation("FollowFollowing", fields: [followingUserId], references: [id])

  @@unique([followerUserId, followingUserId])
  @@index([followingUserId])
}

model IssueFollow {
  id        String   @id @default(cuid())
  userId    String
  issueId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, issueId])
  @@index([issueId])
}

model PublicProfile {
  id                 String               @id @default(cuid())
  claimedByUserId    String?              @unique
  jurisdictionId     String?
  displayName        String
  slug               String               @unique
  profileType        PublicProfileType
  partyText          String?
  bio                String?
  profileImageUrl    String?
  donationUrl        String?
  websiteUrl         String?
  isClaimed          Boolean              @default(false)
  source             PublicProfileSource  @default(admin)
  claimStatus        ClaimStatus?
  claimedByUser      User?                @relation("ClaimedPublicProfile", fields: [claimedByUserId], references: [id])
  jurisdiction       Jurisdiction?        @relation(fields: [jurisdictionId], references: [id])
  candidateCampaigns CandidateCampaign[]
  officialPositions  OfficialPosition[]
  campaignPromises   CampaignPromise[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([claimedByUserId])
  @@index([jurisdictionId])
  @@index([profileType])
}

model Election {
  id                 String               @id @default(cuid())
  jurisdictionId     String
  slug               String               @unique
  title              String
  officeTitle        String
  electionDate       DateTime
  electionType       ElectionType
  status             ElectionStatus       @default(UPCOMING)
  jurisdiction       Jurisdiction         @relation(fields: [jurisdictionId], references: [id])
  candidateCampaigns CandidateCampaign[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([jurisdictionId, status])
  @@index([electionDate])
}

model CandidateCampaign {
  id                 String          @id @default(cuid())
  publicProfileId    String
  electionId         String
  jurisdictionId     String?
  officeSought       String
  partyText          String?
  campaignBio        String?
  donationUrl        String?
  websiteUrl         String?
  status             CampaignStatus  @default(ANNOUNCED)
  isIncumbent        Boolean         @default(false)
  totalRaisedDisplay String?
  topDonorCategories String[]
  pollingSummary     String?
  publicProfile      PublicProfile   @relation(fields: [publicProfileId], references: [id])
  election           Election        @relation(fields: [electionId], references: [id])
  jurisdiction       Jurisdiction?   @relation(fields: [jurisdictionId], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([publicProfileId, electionId])
  @@index([electionId, status])
  @@index([publicProfileId])
}

model CandidateEndorsement {
  id                 String            @id @default(cuid())
  userId             String
  candidateCampaignId String
  isPublic           Boolean           @default(true)
  user               User              @relation(fields: [userId], references: [id])
  candidateCampaign  CandidateCampaign @relation(fields: [candidateCampaignId], references: [id])
  createdAt          DateTime          @default(now())

  @@unique([userId, candidateCampaignId])
  @@index([candidateCampaignId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model OfficialPosition {
  id               String         @id @default(cuid())
  publicProfileId  String
  jurisdictionId   String
  officeTitle      String
  partyText        String?
  isCurrent        Boolean        @default(true)
  startedAt        DateTime?
  endedAt          DateTime?
  publicProfile    PublicProfile  @relation(fields: [publicProfileId], references: [id])
  jurisdiction     Jurisdiction   @relation(fields: [jurisdictionId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([publicProfileId, isCurrent])
  @@index([jurisdictionId])
}

model Jurisdiction {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  type              JurisdictionType
  code              String?
  parentId          String?
  parent            Jurisdiction?     @relation("JurisdictionHierarchy", fields: [parentId], references: [id])
  children          Jurisdiction[]    @relation("JurisdictionHierarchy")
  users             User[]
  posts             Post[]
  petitions         Petition[]
  signatures        PetitionSignature[]
  officialProfiles  OfficialProfile[]
  voteQuestions     VoteQuestion[]
  polls             Poll[]
  communityEvents   CommunityEvent[]
  services          Service[]
  topIssueSubmissions TopIssueSubmission[]
  topIssueUpvotes   TopIssueUpvote[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([parentId])
  @@index([type])
}

model Post {
  id                    String        @id @default(cuid())
  authorId              String
  jurisdictionId        String
  title                 String?
  content               String
  postType              PostType      @default(TEXT)
  contentType           PostContentType @default(announcementUpdate)
  status                PostStatus    @default(PUBLISHED)
  mediaUrl              String?
  mediaThumbnailUrl     String?
  promotedLabel         String?
  mediaTruthScore       Int?
  moderatorTruthScore   Int?
  citizenTruthScore     Int?
  author                User          @relation(fields: [authorId], references: [id])
  jurisdiction          Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  comments              Comment[]
  factualClaimFlags     PostFactualClaimFlag[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([authorId, createdAt(sort: Desc)])
  @@index([jurisdictionId, createdAt(sort: Desc)])
  @@index([status])
}

model Comment {
  id         String   @id @default(cuid())
  postId      String
  userId      String
  content     String
  createdAt   DateTime @default(now())
  post        Post     @relation(fields: [postId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([postId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model PostFactualClaimFlag {
  id        String   @id @default(cuid())
  postId     String
  userId     String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId, createdAt(sort: Desc)])
}

model TruthRating {
  id        String           @id @default(cuid())
  userId    String
  entityId  String
  rating    TruthRatingValue
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@unique([userId, entityId])
  @@index([entityId, createdAt(sort: Desc)])
}

model MediaBiasRating {
  id          String               @id @default(cuid())
  userId      String
  mediaUserId String
  rating      MediaBiasRatingValue
  createdAt   DateTime             @default(now())
  user        User                 @relation(fields: [userId], references: [id])

  @@unique([userId, mediaUserId])
  @@index([mediaUserId, createdAt(sort: Desc)])
}

model Debate {
  id                String            @id @default(cuid())
  title             String
  description       String
  issueId           String
  mode              DebateMode
  startState        DebateStartState  @default(active)
  sideAName         String
  sideBName         String
  createdByUserId   String
  challengedUserId  String?
  status            DebateStatus      @default(open)
  outcomeType       DebateOutcomeType?
  agreedStatement   String?
  sideAGroupTag     String?
  sideBGroupTag     String?
  numberOfRounds    Int               @default(1)
  draftWindowHours  Int?
  votingWindowHours Int?
  createdAt         DateTime          @default(now())
  closedAt          DateTime?
}

model DebateParticipant {
  debateId String
  userId   String
  side     DebateSide
  role     DebateParticipantRole
}

model DebateTurn {
  id              String         @id @default(cuid())
  debateId        String
  side            DebateSide
  turnType        DebateTurnType
  statementText   String
  videoAttachmentUrl String?
  createdByUserId String
  createdAt       DateTime       @default(now())
}

model Citation {
  id           String             @id @default(cuid())
  debateTurnId String
  title        String
  sourceName   String
  sourceType   CitationSourceType?
  url          String
  note         String?
  createdAt    DateTime           @default(now())
}

model DebateTurnReaction {
  id        String                  @id @default(cuid())
  turnId    String
  userId    String
  reaction  DebateTurnReactionType
  createdAt DateTime                @default(now())
}

model DebateFallacyTag {
  id           String             @id @default(cuid())
  debateTurnId String
  userId       String
  fallacyType  DebateFallacyType
  createdAt    DateTime           @default(now())
}

model DebateFallacyReview {
  id           String                     @id @default(cuid())
  debateTurnId String
  fallacyType  DebateFallacyType
  userId       String
  position     DebateFallacyReviewPosition
  createdAt    DateTime                   @default(now())
}

model DebateDraft {
  id              String         @id @default(cuid())
  debateId        String
  side            DebateSide
  turnType        DebateTurnType
  statementText   String
  createdByUserId String
  createdAt       DateTime       @default(now())
}

model DebateDraftVote {
  id        String   @id @default(cuid())
  draftId    String
  userId     String
  createdAt  DateTime @default(now())
}

model DebateFollow {
  id        String   @id @default(cuid())
  userId    String
  debateId  String
  createdAt DateTime @default(now())
}

model DebateCommunityVote {
  id        String                    @id @default(cuid())
  debateId  String
  userId    String
  vote      DebateCommunityVoteOption
  createdAt DateTime                  @default(now())

  @@unique([debateId, userId])
  @@index([debateId, createdAt(sort: Desc)])
}

model ContactAction {
  id         String                  @id @default(cuid())
  userId     String
  entityId   String
  entityType ContactActionTargetType
  officialId String
  method     ContactMethod
  createdAt  DateTime                @default(now())
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityId, entityType, createdAt(sort: Desc)])
  @@index([officialId, createdAt(sort: Desc)])
}

model OfficialAction {
  id                 String                           @id @default(cuid())
  officialProfileId  String
  title              String
  summary            String
  actionType         OfficialActionType
  actionDate         DateTime
  issueTags          String[]
  sourceType         OfficialActionSourceType
  sourceLink         String?
  verificationStatus OfficialActionVerificationStatus
  createdAt          DateTime                         @default(now())

  @@index([officialProfileId, actionDate(sort: Desc)])
}

model OfficialActionReaction {
  id        String                     @id @default(cuid())
  actionId   String
  userId     String
  reaction   OfficialActionReactionType
  createdAt  DateTime                  @default(now())
  user       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actionId, userId])
  @@index([actionId, createdAt(sort: Desc)])
}

model School {
  id                  String   @id @default(cuid())
  name                String
  district            String
  gradeLevels         String[]
  jurisdictionId      String
  enrollment          Int?
  studentTeacherRatio Float?
  createdAt           DateTime @default(now())

  @@index([jurisdictionId])
}

model Petition {
  id                        String              @id @default(cuid())
  creatorId                 String
  organizationId            String?
  jurisdictionId            String
  title                     String
  summary                   String
  body                      String
  status                    PetitionStatus      @default(DRAFT)
  signatureGoal             Int                 @default(5000)
  currentSignatureCount     Int                 @default(0)
  eligibleForCosponsorship  Boolean             @default(false)
  creator                   User                @relation(fields: [creatorId], references: [id])
  jurisdiction              Jurisdiction        @relation(fields: [jurisdictionId], references: [id])
  signatures                PetitionSignature[]
  sponsorshipRequests       SponsorshipRequest[]
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  @@index([creatorId])
  @@index([jurisdictionId, status])
  @@index([organizationId])
}

model VoteQuestion {
  id             String               @id @default(cuid())
  questionText   String
  category       VoteQuestionCategory
  scope          VoteQuestionScope
  jurisdictionId String
  jurisdiction   Jurisdiction         @relation(fields: [jurisdictionId], references: [id])
  responses      VoteResponse[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([jurisdictionId])
  @@index([category])
}

model VoteResponse {
  id         String      @id @default(cuid())
  userId     String
  questionId String
  answer     VoteAnswer
  user       User        @relation(fields: [userId], references: [id])
  question   VoteQuestion @relation(fields: [questionId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([userId, questionId])
  @@index([questionId])
}

model Poll {
  id             String            @id @default(cuid())
  creatorId      String
  question       String
  scope          VoteQuestionScope
  jurisdictionId String
  options        String[]
  expiresAt      DateTime?
  isActive       Boolean           @default(true)
  creator        User              @relation(fields: [creatorId], references: [id])
  jurisdiction   Jurisdiction      @relation(fields: [jurisdictionId], references: [id])
  votes          PollVote[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([creatorId, createdAt(sort: Desc)])
  @@index([jurisdictionId, createdAt(sort: Desc)])
  @@index([scope, createdAt(sort: Desc)])
}

model PollVote {
  id             String   @id @default(cuid())
  pollId         String
  userId         String
  selectedOption String
  poll           Poll     @relation(fields: [pollId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([pollId, userId])
  @@index([userId])
}

model TopIssueSubmission {
  id             String       @id @default(cuid())
  userId         String
  jurisdictionId String
  issueText      String
  scope          VoteQuestionScope
  source         TopIssueSource @default(writeIn)
  user           User         @relation(fields: [userId], references: [id])
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  upvotes        TopIssueUpvote[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([jurisdictionId, scope, createdAt(sort: Desc)])
  @@index([jurisdictionId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model TopIssueUpvote {
  id                String             @id @default(cuid())
  issueSubmissionId String
  userId            String
  jurisdictionId    String?
  issueSubmission   TopIssueSubmission @relation(fields: [issueSubmissionId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  jurisdiction      Jurisdiction?      @relation(fields: [jurisdictionId], references: [id])
  createdAt         DateTime           @default(now())

  @@unique([issueSubmissionId, userId])
  @@index([userId])
  @@index([jurisdictionId])
}

model SponsorshipRequest {
  id                String        @id @default(cuid())
  petitionId        String
  requesterId       String
  targetedOfficials String[]
  petition          Petition      @relation(fields: [petitionId], references: [id])
  requester         User          @relation(fields: [requesterId], references: [id])
  createdAt         DateTime      @default(now())

  @@index([petitionId, createdAt(sort: Desc)])
  @@unique([petitionId, requesterId])
}

model CampaignPromise {
  id              String         @id @default(cuid())
  publicProfileId String
  title           String
  description     String
  category        String?
  status          PromiseStatus?
  notes           String?
  publicProfile   PublicProfile  @relation(fields: [publicProfileId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([publicProfileId])
}

model CreditBoost {
  id          String           @id @default(cuid())
  userId      String
  targetType  CreditBoostTarget
  targetId    String
  creditsSpent Int             @default(3)
  user        User             @relation(fields: [userId], references: [id])
  createdAt   DateTime         @default(now())

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

model CreditTransaction {
  id         String                @id @default(cuid())
  userId     String
  type       CreditTransactionType
  amount     Int
  user       User                  @relation(fields: [userId], references: [id])
  createdAt  DateTime              @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

model CommunityEvent {
  id             String               @id @default(cuid())
  jurisdictionId String
  sponsorUserId  String?
  organizationId String?
  title          String
  description    String
  issueLabel     String?
  startsAt       DateTime
  eventType      CommunityEventType
  format         CommunityEventFormat @default(inPerson)
  locationLabel  String?
  meetingUrl     String?
  sponsorName    String
  sponsorType    CommunitySponsorType
  jurisdiction   Jurisdiction         @relation(fields: [jurisdictionId], references: [id])
  sponsorUser    User?                @relation(fields: [sponsorUserId], references: [id])
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([jurisdictionId, startsAt])
  @@index([sponsorUserId])
  @@index([organizationId])
}

model Organization {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  description      String
  organizationType OrganizationType
  communityId      String
  campusCommunityId String?
  founderUserId    String
  issueTags        String[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([communityId])
  @@index([campusCommunityId])
  @@index([organizationType])
}

model OrganizationMembership {
  id             String                      @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationMembershipRole
  state          OrganizationMembershipState @default(pending)
  createdAt      DateTime                    @default(now())

  @@unique([organizationId, userId])
  @@index([organizationId, state])
  @@index([userId, state])
}

model OrganizationAnnouncement {
  id               String   @id @default(cuid())
  organizationId   String
  createdByUserId  String
  title            String
  body             String
  createdAt        DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
}

model OrganizationPlatformItem {
  id               String                         @id @default(cuid())
  organizationId   String
  createdByUserId  String
  title            String
  description      String
  issueTag         String
  status           OrganizationPlatformItemStatus @default(active)
  createdAt        DateTime                       @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([issueTag])
}

model OrganizationVote {
  id               String                 @id @default(cuid())
  organizationId   String
  platformItemId   String
  userId           String
  choice           OrganizationVoteChoice
  createdAt        DateTime               @default(now())

  @@unique([platformItemId, userId])
  @@index([organizationId, createdAt(sort: Desc)])
}

model OrganizationEndorsement {
  id                 String   @id @default(cuid())
  organizationId     String
  candidateCampaignId String
  statement          String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([candidateCampaignId, createdAt(sort: Desc)])
}

model EventAttendance {
  id          String          @id @default(cuid())
  userId       String
  eventId      String
  status       EventRsvpStatus
  confirmedAt  DateTime?
  createdAt    DateTime        @default(now())
}

model EventPost {
  id         String   @id @default(cuid())
  userId      String
  eventId     String
  content     String
  mediaUrl    String?
  createdAt   DateTime @default(now())
}

model EventSentiment {
  id         String                 @id @default(cuid())
  userId      String
  eventId     String
  value       EventStatementPosition
  createdAt   DateTime               @default(now())
}

model EventStatement {
  id         String                 @id @default(cuid())
  userId      String
  eventId     String
  position    EventStatementPosition
  createdAt   DateTime               @default(now())
}

model EventProposal {
  id                         String   @id @default(cuid())
  proposerUserId             String
  title                      String
  description                String
  purpose                    String
  jurisdictionName           String
  startsAt                   DateTime
  eventType                  String
  format                     String
  locationLabel              String?
  meetingUrl                 String?
  issueLabel                 String?
  approvedByTrustedCitizenId String?
  promotedEventId            String?
  createdAt                  DateTime @default(now())
}

model Service {
  id                 String          @id @default(cuid())
  title              String
  description        String
  category           ServiceCategory
  externalLink       String
  jurisdictionId     String
  responsibleEntity  String
  responsibleOfficialId String?
  relatedIssue       String?
  jurisdiction       Jurisdiction    @relation(fields: [jurisdictionId], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([jurisdictionId, category])
}

model CommunityEconomicSnapshot {
  id                String             @id @default(cuid())
  communityId       String
  level             CommunityDataLevel
  geographyLabel    String
  dataNote          String
  costOfLivingIndex Float
  medianHomePrice   Int?
  medianRent        Int?
  averageIncome     Int?
  costBreakdown     Json
  revenueBreakdown  Json
  spendingBreakdown Json
  createdAt         DateTime           @default(now())

  @@index([communityId, level])
}

model CommunityGroup {
  id             String              @id @default(cuid())
  jurisdictionId String?
  name           String
  type           CommunityGroupType
  description    String
  issueFocuses   String[]
  jurisdiction   Jurisdiction?       @relation(fields: [jurisdictionId], references: [id])
  affiliations   CommunityGroupAffiliation[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([jurisdictionId])
  @@index([type])
}

model CommunityGroupAffiliation {
  id        String         @id @default(cuid())
  groupId    String
  userId     String
  createdAt  DateTime      @default(now())
  group      CommunityGroup @relation(fields: [groupId], references: [id])
  user       User          @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
}

model PetitionSignature {
  id              String           @id @default(cuid())
  petitionId      String
  signerId        String
  jurisdictionId  String
  status          SignatureStatus  @default(PENDING)
  signedAt        DateTime         @default(now())
  petition        Petition         @relation(fields: [petitionId], references: [id])
  signer          User             @relation(fields: [signerId], references: [id])
  jurisdiction    Jurisdiction     @relation(fields: [jurisdictionId], references: [id])

  @@unique([petitionId, signerId])
  @@index([jurisdictionId, status])
  @@index([signerId])
}

model OfficialProfile {
  id                    String        @id @default(cuid())
  userId                String        @unique
  jurisdictionId        String
  officeTitle           String
  officeLevel           String?
  partyAffiliation      String?
  bio                   String?
  profileImageUrl       String?
  platformSummary       String?
  websiteUrl            String?
  isIncumbent           Boolean       @default(true)
  termStart             DateTime?
  termEnd               DateTime?
  followThroughScore    Int?
  truthProfile          OfficialTruthMeter?
  followThroughProfile  OfficialFollowThroughMeter?
  user                  User          @relation(fields: [userId], references: [id])
  jurisdiction          Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([jurisdictionId])
}

model OfficialTruthMeter {
  id                 String           @id @default(cuid())
  officialProfileId  String           @unique
  mediaScore         Int?
  moderatorScore     Int?
  citizenScore       Int?
  updatedAt          DateTime         @updatedAt
  officialProfile    OfficialProfile  @relation(fields: [officialProfileId], references: [id])
}

model OfficialFollowThroughMeter {
  id                 String           @id @default(cuid())
  officialProfileId  String           @unique
  score              Int?
  methodologyNote    String?
  updatedAt          DateTime         @updatedAt
  officialProfile    OfficialProfile  @relation(fields: [officialProfileId], references: [id])
}
