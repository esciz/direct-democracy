model User {
  id                    String            @id @default(cuid())
  email                 String            @unique
  username              String            @unique
  name                  String
  bio                   String?
  avatarUrl             String?
  role                  UserRole          @default(citizen)
  mediaTier             MediaTier?
  isVerifiedVoter       Boolean           @default(false)
  isAnonymousPublic     Boolean           @default(true)
  followerCount         Int               @default(0)
  trustedCitizenAt      DateTime?
  jurisdictionId        String?
  jurisdiction          Jurisdiction?     @relation(fields: [jurisdictionId], references: [id])
  posts                 Post[]
  comments              Comment[]
  factualClaimFlags     PostFactualClaimFlag[]
  truthRatings          TruthRating[]
  mediaBiasRatings      MediaBiasRating[]
  profileContent        UserProfileContent?
  identityTags          UserIdentityTag[]
  petitionsCreated      Petition[]
  petitionSignatures    PetitionSignature[]
  sponsorshipRequests   SponsorshipRequest[]
  voteResponses         VoteResponse[]
  candidateEndorsements CandidateEndorsement[]
  polls                 Poll[]
  pollVotes             PollVote[]
  topIssueSubmissions   TopIssueSubmission[]
  topIssueUpvotes       TopIssueUpvote[]
  topIssues             UserTopIssue[]
  userTags              UserTag[]
  favoriteSpots         FavoriteSpot[]
  creditTransactions    CreditTransaction[]
  creditBoosts          CreditBoost[]
  notifications         Notification[]
  contactActions        ContactAction[]
  issueFollows          IssueFollow[]
  officialActionReactions OfficialActionReaction[]
  caseFollows           CaseFollow[]
  caseSupportStatements SupportStatement[]
  communityBriefThemes  CommunityBriefTheme[]
  communityBriefThemeSupports CommunityBriefThemeSupport[]
  communityGroupAffiliations CommunityGroupAffiliation[]
  communityEvents      CommunityEvent[]
  districtAssignments  UserDistrictAssignment[]
  following            Follow[]           @relation("FollowFollower")
  followers            Follow[]           @relation("FollowFollowing")
  publicProfile         PublicProfile?     @relation("ClaimedPublicProfile")
  officialProfile       OfficialProfile?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([jurisdictionId])
  @@index([role])
}

model UserProfileContent {
  userId             String   @id
  localIssues        String[]
  stateIssues        String[]
  nationalIssues     String[]
  groupTags          String[]
  profession         String?
  experience         String?
  professionPublic   Boolean  @default(false)
  experiencePublic   Boolean  @default(false)
  recentVotesPublic  Boolean  @default(false)
  bookmarkedScopes   VoteQuestionScope[]
  user               User     @relation(fields: [userId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserIdentityTag {
  id        String             @id @default(cuid())
  userId    String
  category  ProfileTagCategory
  value     String
  isCustom  Boolean            @default(false)
  isPublic  Boolean            @default(false)
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])

  @@index([userId, category])
}

model UserTopIssue {
  id        String            @id @default(cuid())
  userId    String
  scope     VoteQuestionScope
  value     String
  isCustom  Boolean           @default(false)
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id])

  @@index([userId, scope])
}

model UserTag {
  id        String   @id @default(cuid())
  userId    String
  value     String
  isCustom  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model IssueSnapshot {
  id          String            @id @default(cuid())
  communityId String
  scope       VoteQuestionScope
  issue       String
  percentage  Int
  date        DateTime

  @@index([communityId, scope, date])
}

model FavoriteSpot {
  id          String           @id @default(cuid())
  userId      String
  name        String
  type        FavoriteSpotType
  user        User             @relation(fields: [userId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

model Case {
  id                   String               @id @default(cuid())
  title                String
  summary              String
  courtLevel           CaseCourtLevel
  stage                CaseStage
  jurisdictionId       String?
  issueTags            String[]
  status               CaseStatus           @default(active)
  keyDatesJson         Json?
  createdAt            DateTime             @default(now())
  jurisdiction         Jurisdiction?        @relation(fields: [jurisdictionId], references: [id])
  follows              CaseFollow[]
  supportStatements    SupportStatement[]
  communityBriefThemes CommunityBriefTheme[]

  @@index([jurisdictionId])
  @@index([courtLevel, stage])
}

model CourtJurisdiction {
  id           String                 @id @default(cuid())
  name         String
  level        CourtJurisdictionLevel
  jurisdiction String
  sourceUrl    String
  accessMethod CourtAccessMethod
  notes        String?
  sourceId     String?
  source       Source?                @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  cases        CourtCase[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([name, sourceUrl])
  @@index([level])
  @@index([jurisdiction])
  @@index([sourceId])
}

model CourtCase {
  id                     String                          @id @default(cuid())
  courtJurisdictionId    String
  sourceId               String?
  caseNumber             String
  caption                String
  caseType               CourtCaseType                  @default(unknown)
  status                 String?
  filingDate             DateTime?
  dispositionDate        DateTime?
  jurisdiction           String
  courtLevel             CourtJurisdictionLevel
  sourceUrl              String?
  publicVisibilityStatus CourtCasePublicVisibilityStatus @default(pending_privacy_review)
  reviewStatus           CivicRecordReviewStatus         @default(pending_review)
  plainEnglishSummary    String?
  lastCheckedAt          DateTime?
  rawData                Json?
  courtJurisdiction      CourtJurisdiction               @relation(fields: [courtJurisdictionId], references: [id], onDelete: Cascade)
  source                 Source?                         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  parties                CourtCaseParty[]
  docketEntries          CourtDocketEntry[]
  documents              CourtDocument[]
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt

  @@unique([courtJurisdictionId, caseNumber])
  @@index([courtJurisdictionId])
  @@index([sourceId])
  @@index([caseNumber])
  @@index([caseType])
  @@index([courtLevel])
  @@index([reviewStatus])
  @@index([publicVisibilityStatus])
  @@index([filingDate])
}

model CourtCaseParty {
  id           String                  @id @default(cuid())
  caseId       String
  partyName    String
  partyRole    String?
  isPublic     Boolean                 @default(false)
  reviewStatus CivicRecordReviewStatus @default(pending_review)
  case         CourtCase               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([caseId])
  @@index([reviewStatus])
  @@index([isPublic])
}

model CourtDocketEntry {
  id           String                  @id @default(cuid())
  caseId       String
  sourceId     String?
  entryDate    DateTime?
  title        String
  description  String?
  documentUrl  String?
  documentType String?
  sourceUrl    String?
  reviewStatus CivicRecordReviewStatus @default(pending_review)
  case         CourtCase               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  source       Source?                 @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  documents    CourtDocument[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([caseId])
  @@index([sourceId])
  @@index([entryDate])
  @@index([reviewStatus])
}

model CourtDocument {
  id                  String                  @id @default(cuid())
  caseId              String
  docketEntryId       String?
  sourceId            String?
  title               String
  documentUrl         String?
  localFilePath       String?
  sourceName          String
  sourceUrl           String?
  documentType        String?
  extractedTextStatus String                  @default("not_started")
  reviewStatus        CivicRecordReviewStatus @default(pending_review)
  case                CourtCase               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  docketEntry         CourtDocketEntry?       @relation(fields: [docketEntryId], references: [id], onDelete: SetNull)
  source              Source?                 @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([caseId])
  @@index([docketEntryId])
  @@index([sourceId])
  @@index([reviewStatus])
}

model CaseFollow {
  id        String   @id @default(cuid())
  caseId     String
  userId     String
  createdAt  DateTime @default(now())
