  jurisdictionId String?
  communityId    String?
  status         String
  assuranceLevel String
  sourceClaimIds String[]
  createdAt      DateTime        @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  account        IdentityAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([snapshotType])
  @@index([status])
  @@index([expiresAt])
}

model IdentityJob {
  id              String   @id
  jobType         String
  status          String
  idempotencyKey  String   @unique
  actorAccountId  String?
  operationId     String?
  parentJobId     String?
  payload         Json     @default("{}")
  attempts        Int      @default(0)
  maxAttempts     Int      @default(3)
  queuedAt        DateTime @default(now())
  nextRunAt       DateTime?
  startedAt       DateTime?
  heartbeatAt     DateTime?
  workerId        String?
  lockedAt        DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  failedAt        DateTime?
  deadLetteredAt  DateTime?
  failureReason   String?
  events          IdentityJobEvent[]

  @@index([jobType])
  @@index([status])
  @@index([queuedAt])
  @@index([nextRunAt])
  @@index([heartbeatAt])
  @@index([workerId])
  @@index([operationId])
  @@index([deadLetteredAt])
}

model AdminOperation {
  id                            String   @id
  operationType                 String
  triggerType                   String
  actorUserId                   String
  actorRole                     String
  permissionsAtTrigger          String[]
  scope                         Json     @default("{}")
  sourceIds                     String[]
  jurisdiction                  String?
  documentType                  String?
  validatedArguments            String[]
  executionBackend              String
  parentOperationId             String?
  retryOfOperationId            String?
  idempotencyKey                String   @unique
  status                        String
  currentStage                  String?
  progressSummary               String
  progress                      Json     @default("{}")
  retryCount                    Int      @default(0)
  createdAt                     DateTime @default(now())
  queuedAt                      DateTime
  startedAt                     DateTime?
  heartbeatAt                   DateTime?
  completedAt                   DateTime?
  cancellationRequested         Boolean  @default(false)
  cancellationReason            String?
  sanitizedResultSummary        String?
  externalRunUrl                String?
  failureClassification         String?
  environmentCapabilitySnapshot Json     @default("{}")
  artifactReferences            String[]
  stages                        AdminOperationStage[]
  auditEvents                   AdminOperationAuditEvent[]
  logReferences                 AdminOperationLogReference[]

  @@index([operationType])
  @@index([status])
  @@index([queuedAt])
  @@index([heartbeatAt])
  @@index([parentOperationId])
}

model AdminOperationStage {
  id          String         @id
  operationId String
  stageName   String
  status      String
  startedAt   DateTime?
  heartbeatAt DateTime?
  completedAt DateTime?
  summary     String?
  metadata    Json           @default("{}")
  operation   AdminOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@unique([operationId, stageName])
  @@index([operationId])
  @@index([status])
}

model AdminOperationAuditEvent {
  id          String         @id
  operationId String
  eventType   String
  actorUserId String?
  summary     String
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())
  operation   AdminOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([operationId])
  @@index([eventType])
  @@index([createdAt])
}

model AdminOperationLogReference {
  id          String         @id
  operationId String
  stream      String
  adapter     String
  objectRef   String
  preview     String?
  createdAt   DateTime       @default(now())
  operation   AdminOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([operationId])
  @@index([stream])
}

model IdentityJobEvent {
  id        String      @id
  jobId     String
  eventType String
  summary   String
  createdAt DateTime    @default(now())
  job       IdentityJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([eventType])
}
